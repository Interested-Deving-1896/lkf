# Desktop kernel config fragment
# Applied on top of defconfig/localyesconfig for desktop targets.
# Inspired by Xanmod and CachyOS desktop tuning.

# Scheduler
CONFIG_HZ_1000=y
CONFIG_HZ=1000
CONFIG_PREEMPT=y

# CPU frequency scaling
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y

# Memory
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=y
CONFIG_ZSWAP=y
CONFIG_ZRAM=m

# Networking
CONFIG_NET_SCH_FQ=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_BBR=y

# Filesystems
CONFIG_BTRFS_FS=m
CONFIG_XFS_FS=m
CONFIG_F2FS_FS=m
CONFIG_EXFAT_FS=m
CONFIG_NTFS3_FS=m

# Virtualization
CONFIG_KVM=m
CONFIG_KVM_INTEL=m
CONFIG_KVM_AMD=m
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y

# Security (balanced)
CONFIG_SECURITY=y
CONFIG_SECURITY_SELINUX=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_STACKPROTECTOR_STRONG=y
