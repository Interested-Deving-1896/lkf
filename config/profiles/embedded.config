# Embedded/appliance kernel config fragment
# Minimal footprint for firmware/appliance targets.
# Inspired by osresearch/linux-builder appliance use case.

CONFIG_HZ_100=y
CONFIG_HZ=100
CONFIG_PREEMPT_NONE=y

# Minimal init
CONFIG_EMBEDDED=y
CONFIG_EXPERT=y

# No modules - everything built-in
CONFIG_MODULES=n

# Minimal filesystems
CONFIG_EXT4_FS=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
# CONFIG_BTRFS_FS is not set
# CONFIG_XFS_FS is not set

# No sound/GPU
# CONFIG_SOUND is not set
# CONFIG_DRM is not set

# Minimal networking
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PACKET=y
# CONFIG_NETFILTER is not set

# Serial console
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# EFI
CONFIG_EFI=y
CONFIG_EFI_STUB=y
