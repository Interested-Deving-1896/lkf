# Server kernel config fragment

CONFIG_HZ_250=y
CONFIG_HZ=250
CONFIG_PREEMPT_NONE=y

# No GUI/sound
# CONFIG_SOUND is not set
# CONFIG_DRM is not set
# CONFIG_FB is not set

# Networking
CONFIG_NET_SCH_FQ=y
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_BBR=y
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=m
CONFIG_NF_TABLES=m

# Containers
CONFIG_NAMESPACES=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_V2=y
CONFIG_BLK_CGROUP=y
CONFIG_MEMCG=y
CONFIG_OVERLAY_FS=m

# Virtualization
CONFIG_KVM=m
CONFIG_VIRTIO=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_BLK=y

# Security (hardened)
CONFIG_SECURITY=y
CONFIG_SECURITY_SELINUX=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_FORTIFY_SOURCE=y
