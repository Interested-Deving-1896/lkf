# Debug kernel config fragment
# Enables KASAN, UBSAN, LOCKDEP, GDB support, QEMU-friendly settings.
# Inspired by deepseagirl/easylkb config.

# GDB support
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_DWARF5=y
CONFIG_GDB_SCRIPTS=y
CONFIG_FRAME_POINTER=y

# KASAN (AddressSanitizer)
CONFIG_KASAN=y
CONFIG_KASAN_INLINE=y

# UBSAN (UndefinedBehaviorSanitizer)
CONFIG_UBSAN=y

# Lock dependency checker
CONFIG_LOCKDEP=y
CONFIG_PROVE_LOCKING=y
CONFIG_DEBUG_LOCKDEP=y

# Memory debugging
CONFIG_KFENCE=y
CONFIG_DEBUG_PAGEALLOC=y
CONFIG_SLUB_DEBUG=y

# Kernel hacking
CONFIG_MAGIC_SYSRQ=y
CONFIG_DEBUG_KERNEL=y
CONFIG_DEBUG_FS=y

# QEMU virtio
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_CONSOLE=y

# Serial console
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# Disable KASLR for easier debugging
# CONFIG_RANDOMIZE_BASE is not set

# Disable LTO for debug builds
# CONFIG_LTO_CLANG_FULL is not set
# CONFIG_LTO_CLANG_THIN is not set
CONFIG_LTO_NONE=y
