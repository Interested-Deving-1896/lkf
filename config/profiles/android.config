# Android kernel config fragment (aarch64)
# Inspired by Biswa96/android-kernel-builder

CONFIG_ANDROID=y
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDERFS=y
CONFIG_ANDROID_LOGGER=y

# ARM64 specifics
CONFIG_ARM64=y
CONFIG_COMPAT=y

# Android ION memory
CONFIG_ION=y

# Binder
CONFIG_ANDROID_BINDER_IPC_SELFTEST=y

# Networking for Android
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_OWNER=y

# Filesystems
CONFIG_F2FS_FS=y
CONFIG_SDCARDFS=y
CONFIG_FUSE_FS=y

# Power management
CONFIG_PM=y
CONFIG_PM_SLEEP=y
CONFIG_SUSPEND=y

# Clang/LLVM
CONFIG_LTO_CLANG_THIN=y
